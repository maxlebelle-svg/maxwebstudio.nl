{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maxwebstudio.nl/schemas/content-factory-adapter/v1/input.json",
  "title": "Content Factory Website Factory Adapter v1 input",
  "type": "object",
  "required": ["vertical"],
  "properties": {
    "vertical": { "type": "string", "minLength": 1 },
    "companyName": { "type": "string" },
    "region": { "type": "string" },
    "tone": { "type": "string" },
    "template": { "type": "string" },
    "package": { "enum": ["starter", "business", "professional", "premium"] },
    "seed": { "oneOf": [{ "type": "integer", "minimum": 0 }, { "type": "string", "minLength": 1 }] },
    "phone": { "type": "string" },
    "email": { "type": "string" },
    "websiteUrl": { "type": "string" }
  },
  "additionalProperties": false
}
