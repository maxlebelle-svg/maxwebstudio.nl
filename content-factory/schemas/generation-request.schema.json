{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maxwebstudio.nl/schemas/content-factory/generation-request.schema.json",
  "title": "Content Factory generation request",
  "type": "object",
  "required": ["branch", "businessName", "place"],
  "properties": {
    "branch": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "businessName": { "type": "string", "minLength": 2 },
    "place": { "type": "string", "minLength": 2 },
    "region": { "type": "string" },
    "phone": { "type": "string" },
    "email": { "type": "string" },
    "seed": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
