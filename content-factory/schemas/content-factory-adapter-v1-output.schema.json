{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maxwebstudio.nl/schemas/content-factory-adapter/v1/output.json",
  "title": "Content Factory Website Factory Adapter v1 output",
  "type": "object",
  "required": ["metadata", "brand", "hero", "services", "about", "usps", "projects", "reviews", "faq", "contactCta", "seo", "assets", "multichannel", "websiteFactoryInput"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["contractVersion", "source", "generatedAt", "contentVersion", "verticalVersion", "requestedVertical", "resolvedVertical", "seed", "fallbacks", "placeholderFlags"]
    },
    "brand": { "type": "object", "required": ["colors", "fonts", "toneOfVoice"] },
    "hero": { "type": "object", "required": ["title", "subtitle", "primaryCta", "asset"] },
    "services": { "type": "array", "minItems": 1 },
    "about": { "type": "object" },
    "usps": { "type": "array", "minItems": 1 },
    "projects": { "type": "array" },
    "reviews": {
      "type": "object",
      "required": ["publicationPolicy", "items"],
      "properties": {
        "publicationPolicy": { "const": "placeholder_only_requires_verified_replacement" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["placeholder", "publishable", "requiresVerifiedReplacement"],
            "properties": {
              "placeholder": { "const": true },
              "publishable": { "const": false },
              "requiresVerifiedReplacement": { "const": true }
            }
          }
        }
      }
    },
    "faq": { "type": "array" },
    "contactCta": { "type": "object" },
    "seo": { "type": "object", "required": ["title", "description", "keywords", "local"] },
    "assets": { "type": "object", "required": ["hero", "services", "about", "gallery", "social"] },
    "multichannel": { "type": "object", "required": ["socialTopics", "blogTopics", "newsletter", "googleBusinessProfile"] },
    "websiteFactoryInput": { "type": "object", "required": ["businessName", "packageType", "template", "services", "ctas", "branding", "texts", "seo"] }
  }
}
