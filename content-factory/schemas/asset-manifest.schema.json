{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maxwebstudio.nl/schemas/content-factory/asset-manifest.schema.json",
  "title": "Max Webstudio Content Factory asset manifest",
  "type": "object",
  "required": ["manifest_version", "storage_root", "slots", "counts_by_type"],
  "properties": {
    "manifest_version": { "type": "string" },
    "storage_root": { "type": "string", "pattern": "^content-library/" },
    "slots": {
      "type": "array",
      "minItems": 51,
      "items": {
        "type": "object",
        "required": ["id", "type", "usage", "subject", "storage_path", "source_resolution", "aspect_ratio", "formats", "alt_text_template", "template_bindings", "prompt", "rights"],
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["hero", "backgrounds", "team", "atmosphere", "gallery", "services", "projects", "reviews", "about", "cta", "icons", "brand", "illustrations", "social", "logos", "video"] },
          "usage": { "enum": ["Hero", "Background", "Gallery", "Services", "About", "Reviews", "CTA", "Social"] },
          "storage_path": { "type": "string", "pattern": "\\.(webp|avif|jpg|png|svg|mp4)$" },
          "source_resolution": {
            "type": "object",
            "required": ["width", "height"],
            "properties": { "width": { "type": "integer", "minimum": 512 }, "height": { "type": "integer", "minimum": 400 } }
          },
          "aspect_ratio": { "type": "string", "pattern": "^[0-9]+:[0-9]+$" },
          "template_bindings": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "prompt": { "$ref": "#/$defs/prompt" }
        }
      }
    }
  },
  "$defs": {
    "prompt": {
      "type": "object",
      "required": ["style", "lighting", "composition", "camera", "color_usage", "subject", "negative_prompt", "suitable_for"],
      "properties": {
        "style": { "type": "string" }, "lighting": { "type": "string" }, "composition": { "type": "string" },
        "camera": { "type": "string" }, "color_usage": { "type": "string" }, "subject": { "type": "string" },
        "negative_prompt": { "type": "string" }, "suitable_for": { "type": "string" }
      }
    }
  }
}
