{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maxwebstudio.nl/schemas/content-factory/composition-blueprint-v2.json",
  "title": "Channel-neutral Content Library composition blueprint v2",
  "type": "object",
  "required": ["contract_version", "composition_signature", "dimensions", "design_system", "content_strategy", "blocks", "photography_recipe", "consumers"],
  "properties": {
    "contract_version": { "type": "string" },
    "composition_signature": { "type": "string", "minLength": 8 },
    "dimensions": {
      "type": "object",
      "required": ["vertical", "visual_style", "brand_personality", "theme", "channels"],
      "properties": {
        "vertical": { "type": "object", "required": ["slug", "name", "category"] },
        "visual_style": { "type": "object", "required": ["id", "name"] },
        "brand_personality": { "type": "object", "required": ["id", "name"] },
        "theme": { "enum": ["light", "dark"] },
        "channels": { "type": "array", "minItems": 1 }
      }
    },
    "design_system": {
      "type": "object",
      "required": ["colors", "fonts", "icons", "layout", "buttons", "spacing", "motion", "illustrations"]
    },
    "content_strategy": {
      "type": "object",
      "required": ["base_tone", "personality_voice", "story_angle", "proof_priorities", "priority_blocks", "audience"]
    },
    "blocks": { "type": "array", "minItems": 1 },
    "photography_recipe": {
      "type": "object",
      "required": ["vertical_subject", "visual_style", "personality_modifier", "theme_modifier", "universal_negative_prompt", "human_review_required"]
    },
    "consumers": { "type": "object", "required": ["neutral_contract", "supported", "adapters"] }
  }
}
