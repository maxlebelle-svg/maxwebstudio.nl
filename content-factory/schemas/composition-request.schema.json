{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maxwebstudio.nl/schemas/content-factory/composition-request-v2.json",
  "title": "Content Library composition request v2",
  "type": "object",
  "required": ["vertical"],
  "properties": {
    "vertical": { "type": "string", "minLength": 1 },
    "specialization": { "type": "string" },
    "style": { "type": "string" },
    "brandPersonality": { "type": "string" },
    "theme": { "enum": ["light", "dark"] },
    "goal": { "type": "string" },
    "region": { "type": "string" },
    "locale": { "enum": ["nl-NL", "nl"] },
    "channels": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["website", "social", "blog", "newsletter", "google_business_profile"] }
    },
    "seed": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
